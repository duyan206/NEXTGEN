@model Ktr_GiuaKy.Models.Product

@{
    ViewData["Title"] = Model.Name + " - Details";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #0b0f19;
        color: #f1f5f9;
    }

    .bg-grid {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: 
            linear-gradient(rgba(99, 102, 241, 0.03) 1px, transparent 1px),
            linear-gradient(90deg, rgba(99, 102, 241, 0.03) 1px, transparent 1px);
        background-size: 40px 40px;
        z-index: -2;
        pointer-events: none;
    }

    .bg-glows {
        position: fixed;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(99, 102, 241, 0.07) 0%, transparent 70%);
        top: -10%;
        left: -10%;
        z-index: -1;
        pointer-events: none;
        filter: blur(80px);
    }

    .detail-card {
        background: rgba(17, 24, 30, 0.6);
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(20px);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
    }

    .img-wrapper {
        border-radius: 20px;
        background-color: rgba(11, 15, 25, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
        min-height: 400px;
    }

    .img-wrapper img {
        max-width: 100%;
        height: auto;
        max-height: 380px;
        object-fit: contain;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        filter: drop-shadow(0 15px 30px rgba(0,0,0,0.5));
    }

    .img-wrapper:hover img {
        transform: scale(1.05);
    }

    .spec-table-container {
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        overflow: hidden;
        background: rgba(11, 15, 25, 0.4);
    }

    .spec-item {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: background-color 0.2s ease;
    }

    .spec-item:hover {
        background-color: rgba(255, 255, 255, 0.02);
    }

    .spec-item:last-child {
        border-bottom: none;
    }

    .spec-label {
        font-weight: 700;
        color: #94a3b8;
        font-size: 0.95rem;
    }

    .spec-value {
        color: #f1f5f9;
        font-weight: 500;
        text-align: right;
        max-width: 60%;
    }

    .price-box {
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(14, 165, 233, 0.05) 100%);
        border-radius: 20px;
        padding: 1.75rem;
        margin: 2rem 0;
        border: 1px solid rgba(99, 102, 241, 0.2);
        box-shadow: 0 10px 20px rgba(99, 102, 241, 0.05);
    }

    .price-tag {
        font-size: 2.2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #ffffff 0%, #c7d2fe 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-buy {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        color: white;
        border: none;
        border-radius: 16px;
        padding: 1rem 2.5rem;
        font-weight: 700;
        box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4);
        transition: all 0.3s ease;
    }

    .btn-buy:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 35px rgba(99, 102, 241, 0.6);
        background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
        color: white;
    }

    .back-btn {
        border-radius: 16px;
        padding: 1rem 2rem;
        font-weight: 600;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: #e2e8f0;
        background-color: rgba(255, 255, 255, 0.04);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .back-btn:hover {
        transform: translateX(-4px);
        background-color: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.3);
        color: white;
    }

    .breadcrumb-item a {
        text-decoration: none;
        color: #818cf8;
        font-weight: 600;
    }

    .breadcrumb-item.active {
        color: #94a3b8;
    }
</style>

<div class="bg-grid"></div>
<div class="bg-glows"></div>

<div class="container py-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Showroom</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", new { brandId = Model.BrandId })">@Model.Brand.Name</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="detail-card p-4 p-lg-5">
        <div class="row g-5">
            <!-- Product Image -->
            <div class="col-lg-6">
                <div class="img-wrapper">
                    <img src="@Model.MainImage" alt="@Model.Name" onerror="this.src='https://images.unsplash.com/photo-1587829741301-dc798b83add3?q=80&w=600&auto=format&fit=crop'" />
                </div>
            </div>

            <!-- Product details -->
            <div class="col-lg-6 d-flex flex-column justify-content-between">
                <div>
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <span class="text-uppercase fw-extrabold tracking-wider" style="color: #818cf8; font-weight: 800; letter-spacing: 0.15em;">@Model.Brand.Name</span>
                        
                        @if (Model.Quantity > 0)
                        {
                            <span class="badge px-3 py-2 rounded-pill fw-semibold" style="background-color: rgba(52, 211, 153, 0.15); color: #34d399; border: 1px solid rgba(52, 211, 153, 0.3);">In Stock (@Model.Quantity)</span>
                        }
                        else
                        {
                            <span class="badge px-3 py-2 rounded-pill fw-semibold" style="background-color: rgba(248, 113, 113, 0.15); color: #f87171; border: 1px solid rgba(248, 113, 113, 0.3);">Out of Stock</span>
                        }
                    </div>

                    <h1 class="display-5 fw-extrabold mb-3" style="font-weight: 800; color: white;">@Model.Name</h1>

                    <p class="text-slate-400 fs-5 mb-4" style="color: #94a3b8; line-height: 1.6;">@Model.ShortDescription</p>

                    <div class="price-box">
                        <span class="d-block mb-1 fs-6" style="color: #a5b4fc; font-weight: 600;">Pricing Summary</span>
                        <div class="d-flex align-items-baseline">
                            <span class="price-tag">@String.Format("{0:N0} ₫", Model.Price)</span>
                        </div>
                    </div>

                    <!-- Tech Specs header -->
                    <h4 class="fw-bold mb-3 mt-4" style="font-weight: 700;">Technical Specifications</h4>
                    <div class="spec-table-container mb-4">
                        <div class="spec-item" style="background-color: rgba(255,255,255,0.01);">
                            <span class="spec-label">Brand</span>
                            <span class="spec-value">@Model.Brand.Name</span>
                        </div>
                        <div class="spec-item">
                            <span class="spec-label">Category</span>
                            <span class="spec-value">@Model.Category.Name</span>
                        </div>
                        <div class="spec-item">
                            <span class="spec-label">SKU ID</span>
                            <span class="spec-value font-monospace text-indigo" style="color: #a5b4fc;">@Model.Sku</span>
                        </div>

                        <!-- Parse details configuration if exists -->
                        @if (!string.IsNullOrEmpty(Model.FullDescription))
                        {
                            @if (Model.FullDescription.Contains("|"))
                            {
                                var specs = Model.FullDescription.Split('|');
                                foreach (var spec in specs)
                                {
                                    if (spec.Contains(":"))
                                    {
                                        var parts = spec.Split(':');
                                        <div class="spec-item">
                                            <span class="spec-label">@parts[0].Trim()</span>
                                            <span class="spec-value">@parts[1].Trim()</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="spec-item">
                                            <span class="spec-value text-start w-100">@spec.Trim()</span>
                                        </div>
                                    }
                                }
                            }
                            else
                            {
                                <div class="p-4 border-top" style="border-top-color: rgba(255,255,255,0.05) !important;">
                                    <p class="mb-0 text-slate-300" style="white-space: pre-line; color: #cbd5e1; line-height: 1.6;">@Model.FullDescription</p>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <a href="@Url.Action("Index")" class="btn back-btn">
                        ← Back to Shop
                    </a>
                    
                    @if (Model.Quantity > 0)
                    {
                        <button class="btn btn-buy flex-grow-1">
                            Buy Configuration
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
